<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1920, height=1080" />
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
  <style>
    :root {
      --bg: #030a04;
      --surface: #0a1b10;
      --text-1: #8cff9a;
      --text-2: #4bd17a;
      --text-3: #2f8a4d;
      --accent: #00ff88;
      --bad: #ff6464;
      --font-sans: system-ui, sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { margin: 0; width: 1920px; height: 1080px; overflow: hidden; }
    body { background: var(--bg); color: var(--text-1); font-family: var(--font-sans); }
    .scene-wrapper { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
    .content-area { text-align: center; max-width: 1600px; padding: 60px; }
    .scene-title { font-size: 52px; font-weight: 600; color: var(--accent); margin-bottom: 24px; }
    .scene-text { font-size: 32px; color: var(--text-2); line-height: 1.5; }
  </style>
</head>
<body>
  <div id="scene" class="scene-wrapper" data-composition-id="{{ scene_id }}"
       data-start="0" data-duration="{{ duration }}"
       data-width="1920" data-height="1080">
    <div class="content-area">
      <div id="title" class="clip scene-title" data-start="0" data-duration="{{ duration }}" data-track-index="0">{{ title }}</div>
      <div id="text" class="clip scene-text" data-start="0.5" data-duration="{{ duration - 0.5 }}" data-track-index="1">{{ content }}</div>
    </div>
  </div>

  <script>
    window.__timelines = window.__timelines || {};
    const tl = gsap.timeline({ paused: true });
    tl.from("#title", { opacity: 0, y: -30, duration: 0.8, ease: "power3.out" }, 0);
    tl.from("#text", { opacity: 0, y: 20, duration: 0.6, ease: "power3.out" }, 0.5);
    window.__timelines["{{ scene_id }}"] = tl;
  </script>
</body>
</html>
