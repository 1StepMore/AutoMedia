# AutoMedia Environment Configuration
#
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# The pipeline reads .env automatically at startup.
# Priority: environment variables > .env > file config > built-in defaults
#
# All AUTOMEDIA_* variables map to automedia/manifests/defaults.yaml keys.

# ============================================================
# LLM Provider
# ============================================================

# Supported providers: deepseek, openai, zhipu, moonshot, qwen, anthropic
AUTOMEDIA_LLM_PROVIDER=deepseek

# Model identifier (e.g. deepseek-chat, gpt-4o, claude-3-opus, moonshot-v1)
AUTOMEDIA_LLM_MODEL=deepseek-chat

# API base URL for the provider
AUTOMEDIA_LLM_BASE_URL=https://api.deepseek.com/v1

# API key (required — the pipeline will fail to start without it)
AUTOMEDIA_LLM_API_KEY=sk-your-key-here

# LLM sampling parameters (optional)
# AUTOMEDIA_LLM_TEMPERATURE=0.7
# AUTOMEDIA_LLM_MAX_TOKENS=4096

# ============================================================
# Pipeline
# ============================================================

# Default brand identifier for automedia run (overridable via --brand flag)
AUTOMEDIA_DEFAULT_BRAND=my-brand

# Default pipeline mode: auto, text_only, video_only, qa_only
AUTOMEDIA_DEFAULT_MODE=auto

# Root directory for AutoMedia projects (defaults to working directory)
# AUTOMEDIA_PROJECTS_DIR=/var/automedia/projects

# ============================================================
# MCP Server
# ============================================================

# Path to the MCP allowlist YAML file (optional).
# When unset, the server looks for mcp_allowlist.yaml next to the server module.
AUTOMEDIA_MCP_ALLOWLIST_PATH=/etc/automedia/mcp_allowlist.yaml

# ============================================================
# Paths (override defaults from automedia/manifests/defaults.yaml)
# ============================================================

AUTOMEDIA_DATA_DIR=./data
AUTOMEDIA_OUTPUT_DIR=./output
# AUTOMEDIA_CACHE_DIR=./cache
# AUTOMEDIA_LOG_DIR=./logs
AUTOMEDIA_POOL_DB=./data/pool.db

# ============================================================
# Credentials & Security
# ============================================================

# Keyring backend preference: auto, secret-service, kwallet
AUTOMEDIA_KEYRING_BACKEND=auto

# Master key for AES-256-GCM credential encryption (required for AccountStore).
# Minimum 16 characters. Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
# AUTOMEDIA_MASTER_KEY=your-master-key-here

# Log format: "json" for log aggregators, "console" for human-readable terminal output
# AUTOMEDIA_LOG_FORMAT=console

# ============================================================
# External API Keys (optional)
# ============================================================

# Tavily Search API key for topic pool collection (optional).
# When unset, _search_tavily() returns an empty list gracefully.
# Get a key at https://tavily.com/api
# AUTOMEDIA_TAVILY_API_KEY=tvly-your-key-here

# ============================================================
# Notifications (optional)
# ============================================================

# Feishu/Lark webhook URL for publishing notifications
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# WeChat Official Account credentials
# WX_APPID=your-app-id
# WX_APPSECRET=your-app-secret

# ============================================================
# Omni Triad Integration (optional)
# ============================================================
# See docs/omni-integration.md for configuration details.
# OPP (pre-processing), OL (localization), ORF (re-formatting)
