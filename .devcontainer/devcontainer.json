{
  "name": "AutoMedia Dev",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "postCreateCommand": "pre-commit install && automedia init --template minimal",
  "remoteUser": "vscode"
}
