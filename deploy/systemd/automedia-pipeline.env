# AutoMedia Pipeline — environment variable template
#
# Copy this file to /etc/automedia/automedia-pipeline.env and fill in
# the values for your deployment.
#
#   sudo mkdir -p /etc/automedia
#   sudo cp deploy/systemd/automedia-pipeline.env /etc/automedia/automedia-pipeline.env
#   sudo chmod 600 /etc/automedia/automedia-pipeline.env
#   # edit the file with your editor
#   sudo systemctl start automedia-pipeline.service
#
# --- Pipeline Parameters ---

# Required. The topic to produce content about.
# AUTOMEDIA_TOPIC=Your Topic Here

# Required. The brand profile to use (must match a profile in your config).
# AUTOMEDIA_BRAND=my-brand

# Pipeline mode.  One of: auto, text_only, video_only, qa_only.
# AUTOMEDIA_MODE=auto

# --- LLM Provider (shared with automedia.conf) ---

# If you already set these in /etc/automedia/automedia.conf you can
# omit them here.  Uncomment only if this service needs different values.
# AUTOMEDIA_LLM_API_KEY=sk-your-key-here
# AUTOMEDIA_LLM_PROVIDER=deepseek
# AUTOMEDIA_LLM_MODEL=deepseek-chat
# AUTOMEDIA_LLM_BASE_URL=https://api.deepseek.com/v1

# --- Path Overrides (optional) ---

# Root directory for AutoMedia projects.  Defaults to the working directory.
# AUTOMEDIA_PROJECTS_DIR=/var/automedia/projects
