# AutoMedia MCP Server — environment variable template
#
# Copy this file to /etc/automedia/automedia-mcp.env and fill in the
# values for your deployment.
#
#   sudo mkdir -p /etc/automedia
#   sudo cp deploy/systemd/automedia-mcp.env /etc/automedia/automedia-mcp.env
#   sudo chmod 600 /etc/automedia/automedia-mcp.env
#   # edit the file with your editor
#   sudo systemctl restart automedia-mcp
#
# --- LLM Provider ---

# Required. The LLM API key for the provider your pipeline uses.
# AUTOMEDIA_LLM_API_KEY=sk-your-key-here

# The LLM provider name. Supported: deepseek, openai, zhipu, moonshot, qwen.
# AUTOMEDIA_LLM_PROVIDER=deepseek

# The model identifier to use (e.g. deepseek-chat, gpt-4o, etc.).
# AUTOMEDIA_LLM_MODEL=deepseek-chat

# Custom API base URL (optional — leave empty to use the provider default).
# AUTOMEDIA_LLM_BASE_URL=https://api.deepseek.com/v1

# --- MCP Server ---

# Path to the MCP allowlist YAML file (optional).
# If not set, the server looks for mcp_allowlist.yaml next to the server module.
# AUTOMEDIA_MCP_ALLOWLIST_PATH=/etc/automedia/mcp_allowlist.yaml

# --- Notifications (optional) ---

# Feishu/Lark webhook URL for publishing notifications.
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# WeChat Official Account credentials (optional).
# WX_APPID=your-app-id
# WX_APPSECRET=your-app-secret

# --- Path Overrides (optional) ---

# Root directory for AutoMedia projects.  Defaults to the working directory.
# AUTOMEDIA_PROJECTS_DIR=/mnt/d/AutoMedia/projects
